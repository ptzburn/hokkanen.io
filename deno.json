{
  "nodeModulesDir": "manual",
  "tasks": {
    "dev:app": "deno run --allow-env --allow-sys --allow-ffi --env-file --allow-net --allow-read --allow-write --allow-run vite --port 3028",
    "build": "deno run --allow-env --allow-read --allow-sys --allow-run --allow-ffi --env-file=.env.prod --allow-write vite build",
    "dev": "concurrently \"deno task dev:app\" \"docker compose up\"",
    "start": "deno run --allow-net --allow-read --allow-write --allow-ffi --allow-env --env-file=.env.prod --allow-sys ./.output/server/index.mjs",
    "db:generate": "deno -A --node-modules-dir --env-file drizzle-kit generate",
    "db:migrate": "deno -A --node-modules-dir --env-file drizzle-kit migrate",
    "db:studio": "deno -A --node-modules-dir --env-file drizzle-kit studio --port 8000",
    "db-prod:migrate": "deno -A --node-modules-dir --env-file=.env.prod drizzle-kit migrate",
    "db-prod:studio": "deno -A --node-modules-dir --env-file=.env.prod drizzle-kit studio --port 8000",
    "check": "deno fmt ./src/ && deno lint ./src/ && deno check ./src/",
    "test": "deno -A --node-modules-dir vitest run",
    "test:watch": "deno -A --node-modules-dir vitest",
    "test:e2e": "./node_modules/.bin/playwright test",
    "test:e2e:install": "./node_modules/.bin/playwright install --with-deps chromium"
  },
  "lint": {
    "rules": {
      "include": [
        "explicit-function-return-type",
        "eqeqeq",
        "camelcase",
        "guard-for-in",
        "no-inferrable-types",
        "no-slow-types",
        "verbatim-module-syntax",
        "single-var-declarator",
        "triple-slash-reference",
        "no-useless-rename",
        "no-self-compare",
        "no-throw-literal",
        "no-sync-fn-in-async-fn",
        "no-sparse-arrays",
        "no-console",
        "no-eval",
        "no-await-in-loop",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "explicit-module-boundary-types"
      ],
      "exclude": [
        "jsx-key"
      ],
      "tags": [
        "recommended",
        "jsx"
      ]
    },
    "plugins": [
      "jsr:@ayk/lint-import-order",
      "jsr:@ryu/deno-lint-plugin-tailwindcss"
    ]
  },
  "imports": {
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.1043.0",
    "@iconify-json/lucide": "npm:@iconify-json/lucide@^1.2.105",
    "@jsquash/jpeg": "npm:@jsquash/jpeg@^1.6.0",
    "@jsquash/png": "npm:@jsquash/png@^3.1.1",
    "@jsquash/resize": "npm:@jsquash/resize@^2.1.1",
    "@jsquash/webp": "npm:@jsquash/webp@^1.5.0",
    "@iconify-json/simple-icons": "npm:@iconify-json/simple-icons@^1.2.81",
    "@solid-primitives/upload": "npm:@solid-primitives/upload@^0.1.4",
    "date-fns": "npm:date-fns@^4.1.0",
    "solid-qr-code": "npm:solid-qr-code@^0.1.11",
    "unplugin-icons": "npm:unplugin-icons@^23.0.1",
    "~/": "./src/",
    "@nerimity/solid-turnstile": "npm:@nerimity/solid-turnstile@^1.1.0",
    "@ark-ui/solid": "npm:@ark-ui/solid@^5.36.2",
    "@better-auth/drizzle-adapter": "npm:@better-auth/drizzle-adapter@^1.6.9",
    "@better-auth/passkey": "npm:@better-auth/passkey@^1.6.9",
    "@milkdown/crepe": "npm:@milkdown/crepe@^7.20.0",
    "@milkdown/ctx": "npm:@milkdown/ctx@^7.20.0",
    "@milkdown/prose": "npm:@milkdown/prose@^7.20.0",
    "@milkdown/utils": "npm:@milkdown/utils@^7.20.0",
    "@corvu/calendar": "npm:@corvu/calendar@^0.1.2",
    "@corvu/drawer": "npm:@corvu/drawer@^0.2.4",
    "@corvu/otp-field": "npm:@corvu/otp-field@^0.1.4",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@1.0.6",
    "@kobalte/core": "npm:@kobalte/core@^0.13.11",
    "@kobalte/tailwindcss": "npm:@kobalte/tailwindcss@^0.9.0",
    "@libsql/client": "npm:@libsql/client@^0.17.3",
    "@playwright/test": "npm:@playwright/test@^1.56.1",
    "@solidjs/meta": "npm:@solidjs/meta@^0.29.4",
    "@solidjs/router": "npm:@solidjs/router@^0.16.1",
    "@solidjs/start": "npm:@solidjs/start@^2.0.0-alpha.2",
    "@solidjs/testing-library": "npm:@solidjs/testing-library@^0.8.10",
    "@solidjs/vite-plugin-nitro-2": "npm:@solidjs/vite-plugin-nitro-2@^0.1.0",
    "@tailwindcss/typography": "npm:@tailwindcss/typography@^0.5.16",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.4",
    "@tanstack/solid-form": "npm:@tanstack/solid-form@^1.29.1",
    "@testing-library/jest-dom": "npm:@testing-library/jest-dom@^6.9.1",
    "@testing-library/user-event": "npm:@testing-library/user-event@^14.6.1",
    "better-auth": "npm:better-auth@^1.6.9",
    "class-variance-authority": "npm:class-variance-authority@^0.7.1",
    "clsx": "npm:clsx@^2.1.1",
    "cmdk-solid": "npm:cmdk-solid@^1.1.2",
    "concurrently": "npm:concurrently@^9.2.1",
    "drizzle-kit": "npm:drizzle-kit@^1.0.0-beta.22",
    "drizzle-orm": "npm:drizzle-orm@^1.0.0-beta.22",
    "drizzle-zod": "npm:drizzle-zod@^0.8.3",
    "embla-carousel-solid": "npm:embla-carousel-solid@^8.6.0",
    "happy-dom": "npm:happy-dom@^20.0.5",
    "lefthook": "npm:lefthook@^2.1.6",
    "rehype-external-links": "npm:rehype-external-links@^3.0.0",
    "rehype-raw": "npm:rehype-raw@^7.0.0",
    "rehype-sanitize": "npm:rehype-sanitize@^6.0.0",
    "rehype-stringify": "npm:rehype-stringify@^10.0.1",
    "remark-gfm": "npm:remark-gfm@^4.0.1",
    "remark-parse": "npm:remark-parse@^11.0.0",
    "remark-rehype": "npm:remark-rehype@^11.1.2",
    "solid-js": "npm:solid-js@^1.9.12",
    "unified": "npm:unified@^11.0.5",
    "solid-sonner": "npm:solid-sonner@^0.3.1",
    "tailwind-merge": "npm:tailwind-merge@^3.5.0",
    "tailwindcss": "npm:tailwindcss@^4.2.4",
    "tailwindcss-animate": "npm:tailwindcss-animate@^1.0.7",
    "tw-animate-css": "npm:tw-animate-css@^1.4.0",
    "unist-util-visit": "npm:unist-util-visit@^5.0.0",
    "vite": "npm:vite@^7.3.2",
    "vite-plugin-solid": "npm:vite-plugin-solid@^2.11.11",
    "vitest": "npm:vitest@^3.2.4",
    "zod": "npm:zod@^4.4.3"
  },
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "strict": true,
    "types": [
      "vite/client",
      "unplugin-icons/types/solid"
    ]
  },
  "allowScripts": ["npm:lefthook"]
}
